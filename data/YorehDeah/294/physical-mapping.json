  "turSeifim": [
    { "seifNumber": 1,  "turFirstWords": "הלכות ערלה ערלה כי תבואו אל הארץ ונטעתם" },
    { "seifNumber": 2,  "turFirstWords": "אבל העלים והלולבים ומי גפנים מותרים" },
    { "seifNumber": 3,  "turFirstWords": "האביונות והתמרות של צלף חייבין בערלה" },
    { "seifNumber": 4,  "turFirstWords": "ואלו שלש שנים אין נמנין מיום ליום", "isCombinedWithNext": true },
    { "seifNumber": 5,  "turFirstWords": null, "isCombinedWithPrev": true },
    { "seifNumber": 6,  "turFirstWords": "שנה חמישית נקראין רבעי ויש להן דין מעשר שני" },
    { "seifNumber": 7,  "turFirstWords": "כתב הרמב\"ם שאין נטע רבעי נוהג בחוץ לארץ" },
    { "seifNumber": 8,  "turFirstWords": "ערלה נוהג בכ\"מ ובכל זמן בין בשל נכרי" },
    { "seifNumber": 9,  "turFirstWords": "הלכך בארץ ישראל ספיקה אסור ובחוצה לארץ ספיקה מותר" },
    { "seifNumber": 10, "turFirstWords": null, "isSaOriginal": true },
    { "seifNumber": 11, "turFirstWords": null, "isSaOriginal": true },
    { "seifNumber": 12, "turFirstWords": "אסור ליטע פרי של ערלה ואם נטעו הפירות" },
    { "seifNumber": 13, "turFirstWords": null, "isSaOriginal": true },
    { "seifNumber": 14, "turFirstWords": "לומר לנכרי טול אתה שני ערלה ואני אטול" },
    { "seifNumber": 15, "turFirstWords": "אם באו לחשבון לומר כמה פירות אכל בשני הערלה" },
    { "seifNumber": 16, "turFirstWords": "אחד הנוטע גרעין או יחור שעקר כל האילן ונטע" },
    { "seifNumber": 17, "turFirstWords": "אע\"פ שמנהג עובדי אדמה להבריך הגפנים בכל שנה" },
    { "seifNumber": 18, "turFirstWords": "אילן שנקצץ וחזר וגדל מהשורש" },
    { "seifNumber": 19, "turFirstWords": "אילן שעקרו רוח או שטפו נהר והוליכו למקום אחר" },
    { "seifNumber": 20, "turFirstWords": "אילן שנעקר ונשאר משרשיו מחובר אפי' כעובי המחט" },
    { "seifNumber": 21, "turFirstWords": "ילדה שאינה גבוה טפח חייבת בערלה לעולם" },
    { "seifNumber": 22, "turFirstWords": "בריכה שנפסקה אם הרכיב ענף מלא פירות של ערלה" },
    { "seifNumber": 23, "turFirstWords": "הנוטע עץ מאכל ואין דעתו לצורך אכילה" },
    { "seifNumber": 24, "turFirstWords": "הנוטע לצורך מצוה כגון לצורך לולב או אתרוג" },
    { "seifNumber": 25, "turFirstWords": "הנוטע בתוך שלו לצורך רבים חייב" },
    { "seifNumber": 26, "turFirstWords": "הנוטע בד\"ה לצורך עצמו והגזלן שנטע" },
    { "seifNumber": 27, "turFirstWords": "עולה מאליו ול\"ש נטעו אינו חייב אא\"כ עושה טפילה" },
    { "seifNumber": 28, "turFirstWords": null, "isSaOriginal": true }
  ],
